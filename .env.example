PORT=3000
NODE_ENV=development

# Authentication PINs — REPLACE BEFORE DEPLOY. The server logs a red warning at startup
# if any super_admin still has one of the well-known defaults (1234, 5678, 9012, etc.).
ADMIN_PIN=CHANGE_ME
JUDGE_PIN=CHANGE_ME
CHAIR_PIN=CHANGE_ME

# Database password — change before first run in any non-throwaway environment.
DB_PASSWORD=CHANGE_ME

# Station agent auth. REQUIRED in production — the server refuses to start if unset.
# Generate with:  openssl rand -hex 32  (or any other random 32+ char string)
# Every station's config.json bakes this in via the admin-only installer download, so
# rotating it means redistributing the installer to each station.
STATION_TOKEN=CHANGE_ME
